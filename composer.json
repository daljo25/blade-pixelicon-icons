{
  "name": "daljo25/blade-pixelicon-icons",
  "type": "laravel-package",
  "version": "1.0.0",
  "description": "Blade Icons package for Pixel Icon Library.",
  "keywords": [
    "laravel",
    "blade",
    "icons",
    "pixelicon"
  ],
  "homepage": "https://github.com/daljo25/blade-pixelicon-icons",
  "license": "MIT",
  "authors": [
    {
      "name": "Daljomar Morillo"
    }
  ],
  "require": {
    "php": "^8.2",
    "blade-ui-kit/blade-icons": "^1.6",
    "illuminate/support": "^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Daljo25\\BladePixelIconIcons\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Daljo25\\BladePixelIconIcons\\BladePixelIconIconsServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
